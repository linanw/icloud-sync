[Unit]
Description=Watch local iCloud sync folder (generated from config.json by install-units.py)
Documentation=man:systemd.path(5)

[Path]
PathChanged=/home/linanw/#icloud_sync
PathModified=/home/linanw/#icloud_sync
Unit=icloud-sync-path.service
MakeDirectory=true
DirectoryMode=0755

[Install]
WantedBy=default.target
